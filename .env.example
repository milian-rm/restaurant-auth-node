# Copia a .env: cp .env.example .env
#
# Puertos:
#   Local (pnpm dev): 3000
#   Docker Compose:   3007

NODE_ENV=development
PORT=3000

# PostgreSQL - desarrollo local
# Con Postgres del stack Docker desde el host, usa puerto 5435
DATABASE_URL=postgresql://IN6AV:change-me-postgres-password@localhost:5435/kinal_sports

# PostgreSQL - variables alternativas (Docker Compose las inyecta internamente)
DB_HOST=localhost
DB_PORT=5435
DB_NAME=kinal_sports
DB_USERNAME=IN6AV
DB_PASSWORD=change-me-postgres-password

# JWT (debe coincidir con auth-service y server-user)
JWT_SECRET=change-me-jwt-secret-min-256-bits
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_EXPIRES_DAYS=30
ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_ISSUER=AuthService
JWT_AUDIENCE=AuthService

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_ENABLE_SSL=true
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@example.com
SMTP_FROM_NAME=Your App Name

# Cloudinary - perfiles de usuario
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your-cloud-name/image/upload/
CLOUDINARY_FOLDER=restaurant_auth/profiles
CLOUDINARY_DEFAULT_AVATAR_FILENAME=avatar-default.png

# Uploads locales (fallback)
UPLOAD_PATH=./uploads/profiles/

# Seguridad
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MS=1800000
VERIFICATION_EMAIL_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1

# App
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_ALLOWED_ORIGINS=http://localhost:5173

# IP filtering (opcional)
BLACKLISTED_IPS=
WHITELISTED_IPS=
RESTRICTED_PATHS=/api/v1/admin
